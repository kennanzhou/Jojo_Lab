# Copy this file to deploy.local.env and edit for your machine.
# deploy.local.env is gitignored; everyone runs the same command:
#   bash scripts/deploy-jojo-lab.sh

# Required if your key is not at ../.ssh/cynadu-ssh.pem or ~/.ssh/cynadu-ssh.pem
# Windows Git Bash example:
# JOJO_SSH_KEY="/d/private-workspace/home-workspace/0528AI/.ssh/cynadu-ssh.pem"
# macOS example:
# JOJO_SSH_KEY="/Users/you/Documents/cynadu-ssh.pem"

JOJO_SSH_KEY=""

# Optional overrides (defaults are fine for shared prod deploy):
# JOJO_SSH_HOST="root@47.86.175.205"
# JOJO_REMOTE_DIR="/opt/jojo-lab"
# JOJO_APP_VERSION="1.0.1"
